[gd_scene load_steps=5 format=3 uid="uid://dvexampleencyclopedia"]

[ext_resource type="Script" path="res://scripts/ui/EncyclopediaUI.gd" id="1_encyclopedia"]
[ext_resource type="Script" path="res://scripts/ui/ButtonSound.gd" id="2_btn_sound"]

[sub_resource type="StyleBoxFlat" id="sb_bg"]
bg_color = Color(0.08, 0.08, 0.12, 0.95)
corner_radius_top_left = 8
corner_radius_top_right = 8
corner_radius_bottom_left = 8
