[node name="EncyclopediaUI" type="CanvasLayer"]
layer = 7
script = ExtResource("1_encyclopedia")

[node name="Dim" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0, 0, 0, 0.5)
